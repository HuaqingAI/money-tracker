# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# AI — 主模型 GPT-5.3-Codex
AI_PRIMARY_API_KEY=your-gpt-codex-api-key
AI_PRIMARY_BASE_URL=https://api.openai.com/v1

# AI — 降级模型 Qwen 3.6-Plus
AI_FALLBACK_API_KEY=your-qwen-api-key
AI_FALLBACK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Auth — 微信
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# Auth — 阿里云 SMS
SMS_ACCESS_KEY_ID=your-aliyun-sms-key
SMS_ACCESS_KEY_SECRET=your-aliyun-sms-secret
SMS_SIGN_NAME=了然
SMS_TEMPLATE_CODE=SMS_000000

# App
NEXT_PUBLIC_API_URL=http://localhost:3000

# Monitoring — Sentry (API / apps/api)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT_API=
SENTRY_PROJECT_MOBILE=
SENTRY_AUTH_TOKEN=

# Monitoring — Sentry (Mobile / apps/mobile, EXPO_PUBLIC_* 在构建时注入)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging — pino (apps/api)
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=7

# Production deployment — Docker Compose / ECS
# Production deployments should override NEXT_PUBLIC_API_URL with the public HTTPS endpoint.
# Example: https://api.example.com
DEPLOY_COMPOSE_PROJECT_NAME=money-tracker-prod
DEPLOY_ENV_FILE=deploy/.env.prod
DEPLOY_HEALTHCHECK_URL=https://127.0.0.1/api/health
DEPLOY_HEALTHCHECK_INTERVAL_SECONDS=5
DEPLOY_HEALTHCHECK_TIMEOUT_SECONDS=120
DEPLOY_CERTS_DIR=/etc/letsencrypt/live/api.example.com
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
API_IMAGE=ghcr.io/huaqingai/money-tracker-api:latest

# Self-hosted Supabase credentials for production compose
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=postgres
AUTHENTICATOR_PASSWORD=change-me-authenticator-password
JWT_SECRET=change-me-to-a-random-32-plus-char-secret-xxxxxxxx
JWT_EXPIRY=3600
ENCRYPTION_KEY=change-me-encryption-key-32-plus-chars
ANON_KEY=change-me-anon-jwt
SERVICE_ROLE_KEY=change-me-service-role-jwt
API_EXTERNAL_URL=https://api.example.com
SITE_URL=https://app.example.com
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_JWT_AUD=authenticated
GOTRUE_JWT_ADMIN_ROLES=service_role
GOTRUE_JWT_DEFAULT_GROUP_NAME=authenticated
GOTRUE_MAILER_AUTOCONFIRM=false

# Compose-facing aliases used by deploy/docker-compose.prod.yml
SUPABASE_ANON_KEY=${ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}
SUPABASE_JWT_SECRET=${JWT_SECRET}
