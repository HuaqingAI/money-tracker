# Supabase self-hosted — slim stack environment template
# Copy to .env and fill real values. NEVER commit .env.

# ---- Postgres ----
# Password for the supabase_admin and postgres roles. Use letters + digits only.
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_HOST=db

# Password for the `authenticator` role that PostgREST connects as.
# Must be different from POSTGRES_PASSWORD and rotated independently.
# Created by supabase/migrations/008_create_service_roles.sql.
AUTHENTICATOR_PASSWORD=change-me-authenticator-password

# ---- JWT (MUST be consistent across GoTrue, PostgREST, Kong, app code) ----
# Minimum 32 chars. Rotating this invalidates all issued tokens.
JWT_SECRET=change-me-to-a-random-32-plus-char-secret-xxxxxxxx
JWT_EXPIRY=3600

# Pre-signed JWTs generated from JWT_SECRET with role=anon / role=service_role
# Regenerate via https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=change-me-anon-jwt
SERVICE_ROLE_KEY=change-me-service-role-jwt

# ---- Kong gateway / public URL ----
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3000

# ---- GoTrue (auth) ----
GOTRUE_SITE_URL=${SITE_URL}
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_JWT_SECRET=${JWT_SECRET}
GOTRUE_JWT_EXP=${JWT_EXPIRY}
GOTRUE_JWT_AUD=authenticated
GOTRUE_JWT_ADMIN_ROLES=service_role
GOTRUE_JWT_DEFAULT_GROUP_NAME=authenticated
# Local dev convenience: auto-confirm signups (no SMTP configured).
# Production MUST set this to false and configure GOTRUE_SMTP_* vars.
GOTRUE_MAILER_AUTOCONFIRM=true

# ---- Application layer encryption (pgp_sym_encrypt) ----
# Used by apps/api/lib services to encrypt wechat_unionid / phone_number.
# This key is NEVER stored in the database. Rotating requires re-encrypting
# all affected rows (plan a migration).
ENCRYPTION_KEY=change-me-encryption-key-32-plus-chars
