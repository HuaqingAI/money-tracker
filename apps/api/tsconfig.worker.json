{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": false,
    "composite": false,
    "incremental": false,
    "declaration": false,
    "declarationMap": false,
    "tsBuildInfoFile": "./dist/tsconfig.worker.tsbuildinfo"
  },
  "include": [
    "worker/**/*.ts",
    "lib/logger.ts",
    "sentry.server.config.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
