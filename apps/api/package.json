{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm run build:worker && next build",
    "build:worker": "tsc --project tsconfig.worker.json",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "test": "pnpm exec vitest run --config ../../vitest.config.ts --dir .",
    "worker": "tsx worker/index.ts",
    "worker:start": "node dist/worker/index.js",
    "clean": "rm -rf .next dist"
  },
  "dependencies": {
    "@money-tracker/shared": "workspace:*",
    "@sentry/nextjs": "^8.47.0",
    "@supabase/supabase-js": "^2.47.10",
    "next": "~15.3.0",
    "node-cron": "^4.2.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "pino-roll": "^3.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "~19.1.0",
    "typescript": "~5.7.3"
  }
}
